{
    "output": "HDMI-A-1",
    "layer": "top",
    "position": "top",
    "margin-top": 2,
    "margin-left": 5,
    "margin-right": 5,
    "height": 24,
    "spacing": 4,

    // ==============================================================================
    // DISPOSICIГ“N DE MГ“DULOS (Layout "La Bestia")
    // ==============================================================================
    "modules-left": ["custom/power", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock", "custom/media"],
    "modules-right": ["network", "group/hardware", "temperature", "backlight", "pulseaudio", "bluetooth", "battery", "idle_inhibitor", "custom/notifications", "tray"],


    // --- CONFIGURACIГ“N DETALLADA ---

    // 1. INTERFAZ
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            // Monitor Principal (1-5)
            "1": "п„‘",
            "2": "п„‘",
            "3": "п„‘",
            "4": "п„‘",
            "5": "п„‘",
            // Monitor Secundario (6-10) - Opcional, pero bueno para consistencia
            "6": "п„‘", 
            "7": "п„‘", 
            "8": "п„‘", 
            "9": "п„‘", 
            "10": "п„‘",
            // Iconos adicionales para estado
            "default": "п„‘",
            "active": "п†’",
            "empty": "п„‘",
            "urgent": "пЃЄ"
        }
    },
    
    "hyprland/window": {
        "max-length": 50,
        "separate-outputs": true
    },

    // 2. BOTГ“N DE APAGADO
    "custom/power": {
        "format": "вЏ»",
        "tooltip": false,
        "on-click": "wlogout -l /home/gerardo0/.config/wlogout/layout -s /home/gerardo0/.config/wlogout/style.css -b 3" 
    },

    // 3. FECHA Y HORA
   "clock": {
        "format": "пЂ— {:%H:%M  пЃі %d/%m}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#7aa2f7'><b>{}</b></span>",
                "days": "<span color='#c0caf5'><b>{}</b></span>",
                "weeks": "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays": "<span color='#ff9e64'><b>{}</b></span>",
                "today": "<span color='#f7768e'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "п†ј",
            "default": "пЂЃ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null",
        
        // --- NUEVAS ACCIONES DE CLIC ---
        "on-click": "playerctl play-pause",       // Clic Izquierdo: Pausar/Reanudar
        "on-click-middle": "playerctl next",      // Clic Central (Rueda): Siguiente
        "on-click-right": "playerctl previous"    // Clic Derecho: Anterior
    },

    // 5. GRUPO HARDWARE (Desplegable)
    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "disk"],
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        }
    },

    "cpu": {
        "format": "п‹› {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "пѓ‰ {}%",
        "tooltip": true
    },
    "disk": {
        "format": "п‚  {percentage_used}%",
        "path": "/"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "п‹‰ {temperatureC}В°C",
        "tooltip": false
    },

    // 6. CONECTIVIDAD Y SISTEMA
    "network": {
        "format-wifi": "п‡«  {bandwidthDownBytes}",
        "format-ethernet": "пћ– {bandwidthDownBytes}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "вљ  Off",
        "on-click": "nm-connection-editor"
    },

    "bluetooth": {
        "format": "пЉ” {status}",
        "format-connected": "пЉ” {device_alias}",
        "format-connected-battery": "пЉ” {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "on-click": "blueman-manager"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["п†…", "п„‘"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "пљ©",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "wpctl set-mute toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        // AquГ­ arreglГ© el espaciado (doble espacio despuГ©s del icono)
        "format": "{icon}  {capacity}%",
        "format-charging": "пѓ§  {capacity}%",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        },
        "tooltip": true
    },

    "custom/notifications": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
            "none": "п‚ў",
            "dnd-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-none": "п‡·",
            "inhibited-notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
            "inhibited-none": "п‚ў",
            "dnd-inhibited-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-inhibited-none": "п‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "tray": {
        "spacing": 10
    }
}
